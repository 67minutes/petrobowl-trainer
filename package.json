    "react-dom": "^19.2.7",
    "read-excel-file": "^9.0.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "8.50.0",
    "@typescript-eslint/parser": "8.50.0",
    "autoprefixer": "^10.4.22",
    "eslint": "9.38.0",
    "eslint-config-next": "15.5.19",
    "playwright": "^1.60.0",
    "postcss": "8.5.15",
